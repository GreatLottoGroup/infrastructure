# RPC / 部署账号
ALCHEMY_API_KEY=
DEPLOY_ACCOUNT_PRIVATE_KEY=

# 合约验证（Etherscan V2 统一 API：一把 etherscan.io key 通吃 Base / Arbitrum 全链）
# 注：hardhat.config 只读此单个 key；旧的 BASESCAN_API_KEY / ARBISCAN_API_KEY（V1 各链独立 key）已停用。
ETHERSCAN_API_KEY=

# 注意：owner / supportedTokens 等部署参数已迁到 Ignition 参数文件
# （ignition/parameters/<network>.json），不再走 .env。详见 ignition/parameters/README.md。
